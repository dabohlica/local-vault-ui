# Optional. The app is configured in-app via the setup wizard (stored in data/config.json).
# These only provide DEFAULTS the wizard seeds from — copy to .env.local to override.

# Change only if Ollama runs on a non-default host/port:
OLLAMA_HOST=http://localhost:11434

# Default models offered in the wizard (you can pick others in the UI):
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_VISION_MODEL=llama3.2-vision   # optional, for image ingestion

# Optional: pre-seed the vault path so the wizard starts filled in.
# Colleagues normally set this in the wizard instead.
# VAULT_PATH=/Users/you/path/to/your/vault
